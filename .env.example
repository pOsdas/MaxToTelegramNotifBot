TELEGRAM_BOT_TOKEN="your_telegram_bot_token"

TELEGRAM_CHAT_ID="your_telegram_chat_id"

MAX_WEB_URL=https://web.max.ru/
MAX_CHECK_INTERVAL_SECONDS=3600
MAX_INITIAL_DELAY_SECONDS=5
MAX_PAGE_LOAD_TIMEOUT_MS=60000
MAX_DOM_SETTLE_SECONDS=8
MAX_RETRY_INTERVAL_SECONDS=60

HEADLESS=false

BROWSER_PROFILE_PATH=/app/runtime/browser-profile
SCREENSHOTS_PATH=/app/runtime/screenshots
LOGS_PATH=/app/runtime/logs
DATABASE_PATH=/app/runtime/data/app.db
HEARTBEAT_PATH=/app/runtime/data/heartbeat.json

APP_TIMEZONE=Europe/Moscow
LOG_LEVEL=INFO
SEND_STARTUP_NOTIFICATION=true
SEND_INITIAL_UNREAD=true
AUTH_ALERT_INTERVAL_SECONDS=21600
ERROR_ALERT_INTERVAL_SECONDS=21600
SNAPSHOT_RETENTION_DAYS=30
MAX_CHATS_IN_NOTIFICATION=10
BROWSER_WIDTH=1440
BROWSER_HEIGHT=900
